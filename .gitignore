# ── BISense AI — .gitignore ──

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
.venv/

# Node
node_modules/

# Environment
.env
.env.local
.env.production

# Build artifacts (frontend dist is deployed via Firebase)
src/frontend/dist/

# Indexes
*.faiss
*.index

# OS
.DS_Store
Thumbs.db

# Credentials (NEVER commit)
credentials.json
service-account*.json

# Logs
*.log

# Firebase
.firebase/

# IDE
.idea/
.vscode/
